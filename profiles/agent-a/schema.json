{
  "$id": "https://verana-labs.github.io/verifiable-trust-spec/schemas/v4/mcpi-agent-a-query.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "MCPI Agent A Query Attestation",
  "description": "Schema for Agent A attesting a question/answer exchange in the MCPI demo.",
  "type": "object",
  "properties": {
    "credentialSubject": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "format": "uri"
        },
        "query": {
          "type": "string"
        },
        "answer": {
          "type": "string"
        },
        "responder": {
          "type": "string"
        },
        "verified": {
          "type": "boolean"
        }
      },
      "required": [
        "id",
        "query",
        "answer",
        "responder",
        "verified"
      ]
    }
  }
}
